# Production Environment Configuration
# This file contains production settings - UPDATE WITH YOUR ACTUAL CREDENTIALS

# Project Configuration
PROJECT_NAME="Landsat Image Viewer"
VERSION="1.0.0"
DEBUG=false
HOST="0.0.0.0"
PORT=8000

# Security (UPDATE REQUIRED)
SECRET_KEY="your-super-secret-key-change-in-production-minimum-32-characters"
ACCESS_TOKEN_EXPIRE_MINUTES=11520
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password Security (Argon2)
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=102400
ARGON2_PARALLELISM=8
ARGON2_HASH_LENGTH=32
ARGON2_SALT_LENGTH=16

# Database Configuration (UPDATE REQUIRED - Supabase PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/landsat_db"
SQLITE_DATABASE_URL="sqlite:///app/data/test.db"

# Supabase Configuration (UPDATE REQUIRED)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="landsat-images"

# Redis Configuration
REDIS_URL="redis://redis:6379/0"

# Celery Configuration
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# Email Configuration (UPDATE REQUIRED - Mailchimp)
MAILCHIMP_API_KEY="your-mailchimp-api-key"
MAILCHIMP_FROM_EMAIL="noreply@yourdomain.com"
MAILCHIMP_FROM_NAME="Landsat Image Viewer"

# Landsat API Configuration (UPDATE REQUIRED)
LANDSAT_API_USERNAME="your-landsat-username"
LANDSAT_API_PASSWORD="your-landsat-password"

# CORS Configuration (UPDATE REQUIRED - Add your production domains)
BACKEND_CORS_ORIGINS='["https://yourdomain.com", "https://www.yourdomain.com"]'

# Trusted Hosts (UPDATE REQUIRED - Add your production domains)
ALLOWED_HOSTS='["yourdomain.com", "www.yourdomain.com"]'

# File Storage
TEMP_DIR="/app/temp"
LOGS_DIR="/app/logs"
MAX_UPLOAD_SIZE=104857600

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100

# Nginx Configuration (for production)
NGINX_PORT=80
NGINX_SSL_PORT=443
