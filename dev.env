# Development Environment Configuration
# This file contains development-optimized settings with SQLite and placeholder values

# Project Configuration
PROJECT_NAME="Landsat Image Viewer"
VERSION="1.0.0"
DEBUG=true
HOST="0.0.0.0"
PORT=8000

# Security
SECRET_KEY="dev-secret-key-change-in-production-minimum-32-characters-long"
ACCESS_TOKEN_EXPIRE_MINUTES=11520
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password Security (Argon2)
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=102400
ARGON2_PARALLELISM=8
ARGON2_HASH_LENGTH=32
ARGON2_SALT_LENGTH=16

# Database Configuration (SQLite for development)
DATABASE_URL="sqlite:////app/data/test.db"
SQLITE_DATABASE_URL="sqlite:////app/data/test.db"

# Supabase Configuration (placeholders - not used in development)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="landsat-images"

# Redis Configuration
REDIS_URL="redis://redis:6379/0"

# Celery Configuration
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# Email Configuration (Mailchimp - placeholders for development)
MAILCHIMP_API_KEY="your-mailchimp-api-key"
MAILCHIMP_FROM_EMAIL="noreply@yourdomain.com"
MAILCHIMP_FROM_NAME="Landsat Image Viewer"

# Landsat API Configuration (placeholders for development)
LANDSAT_API_USERNAME="your-landsat-username"
LANDSAT_API_PASSWORD="your-landsat-password"

# CORS Configuration (for development)
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:80", "http://localhost:443"]'

# Trusted Hosts (for development)
ALLOWED_HOSTS='["localhost", "127.0.0.1", "your-domain.com"]'

# File Storage
TEMP_DIR="/app/temp"
LOGS_DIR="/app/logs"
MAX_UPLOAD_SIZE=104857600

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=100

# Nginx Configuration (for development)
NGINX_PORT=80
NGINX_SSL_PORT=443
